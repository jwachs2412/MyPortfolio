<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical origin: force HTTPS + www so every URL resolves to one host.
  # Without this, https://joshwachsman.com/... returns a 200 that is a byte-for-byte
  # duplicate of https://www.joshwachsman.com/..., which is what Google Search Console
  # reports as "Duplicate without user-selected canonical". The 301 consolidates the
  # apex (and any http) URLs onto the indexable www origin in a single hop.
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
  RewriteRule ^ https://www.%1%{REQUEST_URI} [L,R=301]

  # Collapse /index.html to / so the home page has a single canonical URL. THE_REQUEST
  # only matches a literal browser request, so the SPA's internal rewrite below never loops.
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [L,R=301]

  # Any direct request for a prerendered *.html file 301s to its clean,
  # extensionless URL, so each page has exactly one indexable URL (no /foo.html
  # duplicate of /foo). THE_REQUEST is the literal request line, so the internal
  # rewrite further down never triggers this redirect.
  RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [L,R=301]

  # Serve existing files and directories as-is (assets, images, robots.txt, sitemap.xml)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Serve the build-time prerendered HTML at clean URLs. Each route (/sitemap,
  # /projects/<slug>) has a matching <path>.html carrying the correct per-page
  # <head> and content. Unknown paths fall through to the SPA (client renders 404).
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # Otherwise, hand routing to the SPA so client-side routes work on direct load/refresh
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Security headers applied to every response.
  # nosniff: don't let browsers MIME-sniff a response into an unexpected type.
  Header always set X-Content-Type-Options "nosniff"
  # Disallow framing by other origins (clickjacking protection).
  Header always set X-Frame-Options "SAMEORIGIN"
  # HSTS: force HTTPS for a year incl. subdomains. Safe now that all traffic is https+www.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Send origin only on cross-origin requests; full URL stays same-origin.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Hashed Vite bundles in /assets/ are content-addressed and never change — cache hard.
  <FilesMatch "^.+\.(?:css|js|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images: cache a month (filenames aren't hashed, but rarely change).
  <FilesMatch "\.(?:png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML and the sitemap should always re-validate so deploys are picked up immediately.
  <FilesMatch "\.(?:html|xml)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/xml text/plain application/javascript application/json application/xml image/svg+xml
</IfModule>
